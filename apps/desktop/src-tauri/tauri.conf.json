{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gongmu",
  "version": "0.1.0",
  "identifier": "kr.gongmu.workspace",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5173"
  },
  "app": {
    "windows": [
      {
        "title": "공무 업무 에이전트",
        "width": 1440,
        "height": 960,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller",
        "silent": true
      },
      "wix": {
        "template": "windows/main.wxs"
      }
    },
    "resources": {
      "resources/sidecar/windows-x64/gongmu-sidecar": "resources/sidecar/windows-x64/gongmu-sidecar"
    },
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
