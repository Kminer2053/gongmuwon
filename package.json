{
  "name": "gongmu-workspace",
  "private": true,
  "workspaces": [
    "apps/desktop"
  ],
  "scripts": {
    "desktop:dev": "npm --workspace apps/desktop run tauri:dev",
    "sidecar:test": "npm run sidecar:venv:check && node scripts/portable-run.mjs python -m pytest services/sidecar/tests -q",
    "sidecar:serve": "npm run sidecar:venv:check && node scripts/portable-run.mjs python -m uvicorn gongmu_sidecar.app:create_app --factory --app-dir services/sidecar/src --host 127.0.0.1 --port 8765",
    "sidecar:venv:check": "node scripts/repair-python-venv.mjs --check",
    "sidecar:venv:report": "node scripts/repair-python-venv.mjs --check --out docs/operations/generated/python-venv-report.json --markdown docs/operations/generated/python-venv-report.md",
    "sidecar:venv:repair": "node scripts/repair-python-venv.mjs --repair",
    "sidecar:bundle:freshness": "node scripts/check-sidecar-bundle-freshness.mjs --out docs/operations/generated/sidecar-bundle-freshness-report.json",
    "sidecar:smoke:bundled": "node scripts/smoke-bundled-sidecar.mjs",
    "desktop:test": "npm --workspace apps/desktop run test",
    "desktop:build": "npm --workspace apps/desktop run build",
    "desktop:bundle": "npm run sidecar:bundle:windows && node scripts/sync-sidecar-bundle.mjs && npm run sidecar:smoke:bundled && node scripts/tauri-build-with-wix-fallback.mjs",
    "desktop:bundle:debug": "npm run sidecar:bundle:windows && node scripts/sync-sidecar-bundle.mjs && npm run sidecar:smoke:bundled && node scripts/tauri-build-with-wix-fallback.mjs --debug",
    "desktop:smoke:msi": "node scripts/windows-msi-fallback-smoke.mjs",
    "desktop:smoke:nsis": "node scripts/windows-nsis-smoke.mjs",
    "desktop:prepare:gui": "node scripts/windows-gui-validation-helper.mjs",
    "desktop:prepare:anything": "node scripts/windows-anything-validation-helper.mjs",
    "desktop:verify:windows": "node scripts/windows-installer-verify.mjs",
    "desktop:verify:windows:fast": "node scripts/windows-installer-verify.mjs --skip-bundle",
    "sidecar:bundle:windows": "npm run sidecar:venv:check && node scripts/portable-run.mjs python -m PyInstaller --noconfirm --clean --distpath release/sidecar/windows-x64 --workpath runtime-workspace/cache/pyinstaller services/sidecar/packaging/gongmu-sidecar.spec",
    "release:offline": "node scripts/prepare-offline-release.mjs",
    "release:download:gemma4": "node scripts/download-ollama-model-store.mjs --model gemma4:e2b",
    "release:ai-pack": "node scripts/prepare-ollama-ai-pack.mjs",
    "release:ai-pack:validate": "node scripts/validate-ai-pack-artifact.mjs --require-zip --min-zip-bytes 7500000000 --run-launcher-dry-run --parse-powershell --hash-zip",
    "release:ai-pack:evidence:request": "node scripts/prepare-clean-account-evidence-request.mjs",
    "release:ai-pack:evidence:request:validate": "node scripts/validate-clean-account-evidence-request.mjs",
    "release:ai-pack:evidence:import": "node scripts/import-clean-account-evidence.mjs",
    "release:ai-pack:evidence:finalize": "node scripts/finalize-clean-account-evidence.mjs",
    "release:ai-pack:evidence:validate": "node scripts/validate-clean-account-evidence.mjs --evidence docs/operations/generated/clean-account-evidence/ai-pack-clean-account-evidence.json",
    "release:test:ai-pack": "node scripts/download-ollama-model-store.test.mjs && node scripts/prepare-ollama-ai-pack.test.mjs",
    "release:alpha": "node scripts/prepare-alpha-release.mjs",
    "qa:scenarios:lightweight": "node scripts/generate-lightweight-model-test-scenarios.mjs --model gemma4:e2b --per-category 10 --out-dir docs/operations/generated --format both",
    "qa:score:lightweight": "node scripts/score-lightweight-model-test-run.mjs --scenarios docs/operations/generated/lightweight-model-test-scenarios.json --out-dir docs/operations/generated --create-template --create-run-pack",
    "qa:runpack:lightweight": "node scripts/score-lightweight-model-test-run.mjs --scenarios docs/operations/generated/lightweight-model-test-scenarios.json --out-dir docs/operations/generated --create-run-pack",
    "qa:batches:lightweight": "node scripts/score-lightweight-model-test-run.mjs --scenarios docs/operations/generated/lightweight-model-test-scenarios.json --out-dir docs/operations/generated --create-batches",
    "qa:audit:lightweight": "node scripts/score-lightweight-model-test-run.mjs --scenarios docs/operations/generated/lightweight-model-test-scenarios.json --results docs/operations/generated/lightweight-model-test-results-template.json --out-dir docs/operations/generated --audit-coverage",
    "qa:smoke:lightweight": "node scripts/run-lightweight-model-smoke.mjs --base-url http://127.0.0.1:8765 --out-dir docs/operations/generated",
    "qa:record:lightweight": "node scripts/record-lightweight-computer-use-result.mjs --base-url http://127.0.0.1:8765 --out-dir docs/operations/generated",
    "qa:measure:lightweight": "node scripts/measure-lightweight-ux-quality.mjs --base-url http://127.0.0.1:8765 --out-dir docs/operations/generated",
    "qa:test:lightweight": "node scripts/generate-lightweight-model-test-scenarios.test.mjs && node scripts/score-lightweight-model-test-run.test.mjs && node scripts/run-lightweight-model-smoke.test.mjs && node scripts/record-lightweight-computer-use-result.test.mjs && node scripts/measure-lightweight-ux-quality.test.mjs",
    "verify:all": "npm run sidecar:venv:check && npm run sidecar:test && npm run desktop:test && npm run desktop:build && node scripts/portable-run.mjs cargo check --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "verify:completion:test": "node scripts/verify-final-completion.test.mjs && node scripts/final-completion-blockers.test.mjs && node scripts/final-completion-criteria.test.mjs && node scripts/final-completion-preflight.test.mjs && node scripts/check-release-hygiene.test.mjs && node scripts/smoke-bundled-sidecar.test.mjs && node scripts/package-scripts.test.mjs && node scripts/check-sidecar-bundle-freshness.test.mjs && node scripts/sync-sidecar-bundle.test.mjs && node scripts/prepare-offline-release.test.mjs && node scripts/prepare-ollama-ai-pack.test.mjs && node scripts/validate-ai-pack-artifact.test.mjs && node scripts/validate-clean-account-evidence.test.mjs && node scripts/import-clean-account-evidence.test.mjs && node scripts/finalize-clean-account-evidence.test.mjs && node scripts/prepare-clean-account-evidence-request.test.mjs && node scripts/validate-clean-account-evidence-request.test.mjs",
    "verify:completion": "node scripts/verify-final-completion.mjs",
    "verify:completion:blockers": "node scripts/final-completion-blockers.mjs",
    "verify:completion:hygiene": "node scripts/check-release-hygiene.mjs",
    "verify:completion:preflight": "node scripts/final-completion-preflight.mjs",
    "verify:completion:audit": "node scripts/verify-final-completion.mjs --allow-pending && node scripts/final-completion-blockers.mjs"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
